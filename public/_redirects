# Short vote links (site root /round/:slug) are handled by the Pages Function
# functions/round/[[slug]].js, which serves per-round Open Graph tags for link
# previews and then redirects humans into the SPA. Do NOT add a /round redirect
# here or it will shadow the Function's rich preview.

# React SPA at /app/ — do NOT use /app/* here: would break /app/assets/*.js
/app              /app/                 302

# Canonical trailing slash (302) so the splat 200 rules below match.
/app/plan                /app/plan/                 302
/app/share               /app/share/                302
/app/round/:slug         /app/round/:slug/          302
/app/course/:courseId    /app/course/:courseId/     302
/app/account             /app/account/              302
/app/feed                /app/feed/                 302
/app/admin               /app/admin/                302
/app/admin/courses       /app/admin/courses/        302
/app/admin/courses/:slug /app/admin/courses/:slug/  302

# 200 rewrites must target /app/ (directory index), not /app/index.html — the latter
# gets an extra 308 → /app/ and the rewrite can resolve to the wrong HTML.
/app/plan/               /app/                     200
/app/share/              /app/                     200
/app/round/*/            /app/                     200
/app/course/*/           /app/                     200
/app/account/            /app/                     200
/app/feed/               /app/                     200
/app/admin/              /app/                     200
/app/admin/courses/      /app/                     200
/app/admin/courses/*/    /app/                     200
