# Short vote links at site root → SPA (private windows / SMS often omit /app/).
/round/:slug      /app/round/:slug      302

# React SPA at /app/ — do NOT use /app/* here: Cloudflare applies redirects even
# when a static file exists, which would break /app/assets/*.js (see Pages redirects docs).
#
# Use :param placeholders for one-segment routes — splat /app/course/* can fail to rewrite
# on some Pages + wrangler deploys and falls through to the root marketing index.html.
/app              /app/                 302
/app/course/:courseId   /app/index.html       200
/app/plan               /app/index.html       200
/app/share              /app/index.html       200
/app/round/:slug        /app/index.html       200
