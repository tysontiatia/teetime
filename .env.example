# Copy to .env (gitignored) for offline scripts (photo refresh, geocoding, etc.).
GOOGLE_PLACES_KEY=your_google_places_api_key

# Worker secrets (also push with: bash scripts/set-twilio-secrets.sh)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+18015551234
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend local dev: copy frontend/.env.example → frontend/.env.local instead.
# See docs/DEVELOPMENT.md for OAuth redirect URL setup in Supabase.
